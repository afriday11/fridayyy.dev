---
import Navigation from "../components/Navigation.astro";
import "../assets/global.scss";

import { ClientRouter } from "astro:transitions";

// Accept SEO props from child components
const { 
  maxWidth,
  title = "Dan Fessler",
  description = "A personal blog and portfolio website",
  image,
  type = "website",
  publishedTime,
  modifiedTime,
  author = "Dan Fessler"
} = Astro.props;

// Construct the full URL for the image
const fullImageUrl = image ? new URL(image, Astro.site || Astro.url).href : undefined;
const fullUrl = (Astro.site || Astro.url).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.png" />

    <link rel="icon" type="image/png" href="/favicon_180.png" sizes="180x180">
    <link rel="icon" type="image/png" href="/favicon_48.png" sizes="48x48">
    <link rel="icon" type="image/png" href="/favicon_32.png" sizes="32x32">
    <link rel="icon" type="image/png" href="/favicon.png" sizes="16x16">

    <!-- Apple Touch Icon (for iOS homescreen) -->
    <link rel="apple-touch-icon" href="/favicon_180.png"> <!-- 180x180 is standard -->

    <meta name="generator" content={Astro.generator} />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"
    />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#1d1e21" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black" />
    <meta name="format-detection" content="telephone=no" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={fullUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {fullImageUrl && <meta property="og:image" content={fullImageUrl} />}
    <meta property="og:site_name" content="Dan Fessler" />

    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    {author && <meta property="article:author" content={author} />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={fullUrl} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {fullImageUrl && <meta name="twitter:image" content={fullImageUrl} />}
    <meta name="twitter:creator" content="@danfessler" />
    

    <slot name="head" />

    <link
      href="https://fonts.googleapis.com/css?family=Montserrat:300,400&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body>
    <Navigation />
    <div
      class="content"
      style={`max-width: ${maxWidth ? maxWidth + "px" : "100%"};`}
    >
      <slot />
    </div>
  </body>
</html>

<style>
  .content {
    flex-grow: 1;
    position: relative;
    width: calc(75% - 6rem);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    max-width: 100%;
    font-size: 1.1rem;
    /* padding: 0 1rem; */
  }

  .content :global(pre) {
    font-size: 0.9rem !important;
  }

  .content :global(*) {
    /* width: 100%; */
    /* max-width: 100%; */
  }
</style>
