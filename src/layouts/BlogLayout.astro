---
import Layout from "../layouts/Layout.astro";
import Disqus from "../components/Disqus.astro";

const { title, image, tags, author, pubDate, description } =
  Astro.props.content;

// pubDate: 2014-04-12
// needs to convert to ISO 8601 format
const pubDateISO = new Date(pubDate).toISOString();
---

<title>{title}</title>

<Layout 
  maxWidth={1440}
  title={title}
  description={description}
  image={image.url}
  type="article"
  publishedTime={pubDateISO}
  modifiedTime={pubDateISO}
  author={author}
>
  <!-- <pre>{JSON.stringify(theseProps, null, 2)}</pre> -->
  <div class="post-content">
    <p><img src={image.url} alt={image.alt} /></p>
    <h1>{title}</h1>
    <p>
      {tags.join(", ")}
    </p>
    <p>
      {
        new Date(pubDate).toLocaleDateString("en-US", {
          year: "numeric",
          month: "long",
          day: "numeric",
        })
      }
    </p>
    <slot />
    <Disqus />
  </div>
</Layout>

<style>
  .post-content {
    /* text-align: center; */
    /* display: flex;
		flex-direction: column;
		justify-content: flex-start;
		align-items: center; */
    margin: 0;
    /* background: #0000005e; */
    border-radius: 1rem;
    /* padding: 1rem 0; */
    display: flow-root;
  }
  .post-content > :global(*) {
    max-width: 800px;
    width: 100%;
    /* margin-left: auto;
    margin-right: auto; */
    margin: 2rem auto;
    box-sizing: border-box;
    /* margin: 1.5rem auto; */
    /* padding: 2rem; */
  }
  .post-content > :global(p:has(img):first-of-type) {
    max-width: 100%;
    border-radius: 1rem;
    overflow: hidden;

    img {
      width: 100%;
      min-height: 240px;
      object-fit: cover;
    }
  }
  .post-content > :global(p:first-of-type) {
    margin-top: 0;
  }

  .post-content > :global(img) {
    border-radius: 0.5rem;
  }
</style>
