---
import Layout from "../layouts/Layout.astro";
import Card from "../components/Card.astro";

const matches = import.meta.glob("./blog/*.md", { eager: true });
const posts = Object.values(matches);

// sorted by date
const sortedPosts = posts.sort((a, b) => {
  return (
    new Date(b.frontmatter.pubDate).getTime() -
    new Date(a.frontmatter.pubDate).getTime()
  );
});
---

<Layout>
  <h2>Latest post</h2>
  <Card post={sortedPosts[0]} horizontal={true} />

  <h2>All posts</h2>
  <div class="content">
    {sortedPosts.map((post: any, i) => <Card post={post} horizontal={false} />)}
  </div>
</Layout>

<style>
  .content {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    /* grid-auto-columns: 100px;
    grid-template-rows: auto; */
    width: 100%;
    box-sizing: border-box;
    gap: 1rem;
    /* padding: 1rem; */
    position: relative;

    h1 {
      display: flex;
      grid-column: 1 / -1;
    }
  }

  .posts {
    display: flex;
    flex-direction: row;
    gap: 1rem;
    width: 100%;
    justify-content: stretch;
  }
</style>
