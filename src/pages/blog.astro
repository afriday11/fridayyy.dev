---
import Layout from "../layouts/Layout.astro";
import Card from "../components/Card.astro";

const matches = import.meta.glob("./blog/*.md", { eager: true });
const posts = Object.values(matches);
---

<Layout maxWidth="1024">
  <h2>Latest post</h2>
  <Card post={posts[0]} horizontal={true} />

  <h2>All posts</h2>
  <div class="content">
    {posts.map((post: any, i) => <Card post={post} horizontal={false} />)}
  </div>
</Layout>

<style>
  .content {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    /* grid-auto-columns: 100px;
    grid-template-rows: auto; */
    width: 100%;
    box-sizing: border-box;
    gap: 1rem;
    /* padding: 1rem; */
    position: relative;

    h1 {
      display: flex;
      grid-column: 1 / -1;
    }
  }

  .posts {
    display: flex;
    flex-direction: row;
    gap: 1rem;
    width: 100%;
    justify-content: stretch;
  }
</style>
