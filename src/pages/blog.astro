---
import Layout from "../layouts/Layout.astro";

const matches = import.meta.glob("./blog/*.md", { eager: true });
const posts = Object.values(matches);
---

<Layout>
  <h1>Latest posts</h1>
  <div class="content">
    {
      posts.map((post: any, i) => (
        <a class="post card-container shadowfx latest" href={post.url}>

            <div class="post-thumbnail" style={`background-image: url(${post.frontmatter.image.url})`}>
              {/* <img
                src={post.frontmatter.image.url}
                alt={post.frontmatter.image.alt}
              /> */}
            </div>
            <div class="post-content">
              <span class="post-date">
                {new Date(post.frontmatter.pubDate).toLocaleDateString(
                  "en-US",
                  {
                    year: "numeric",
                    month: "long",
                    day: "numeric",
                  }
                )}
              </span>
              <h3>{post.frontmatter.title}</h3>
              <p>{post.frontmatter.description}</p>
            </div>
        </a>
      ))
    }
    <div class="row-break"></div>
  <h1>2024</h1>
    {
      posts.slice(0, 2).map((post: any, i) => (
        <a class="post card-container shadowfx" href={post.url}>

            <div class="post-thumbnail" style={`background-image: url(${post.frontmatter.image.url})`}>
              {/* <img
                src={post.frontmatter.image.url}
                alt={post.frontmatter.image.alt}
              /> */}
            </div>
            <div class="post-content">
              <span class="post-date">
                {new Date(post.frontmatter.pubDate).toLocaleDateString(
                  "en-US",
                  {
                    year: "numeric",
                    month: "long",
                    day: "numeric",
                  }
                )}
              </span>
              <h3>{post.frontmatter.title}</h3>
              <p>{post.frontmatter.description}</p>
            </div>
        </a>
      ))
    }
  <h1>2023</h1>
    {
      posts.map((post: any, i) => (
        <a class="post card-container shadowfx" href={post.url}>

            <div class="post-thumbnail" style={`background-image: url(${post.frontmatter.image.url})`}>
              {/* <img
                src={post.frontmatter.image.url}
                alt={post.frontmatter.image.alt}
              /> */}
            </div>
            <div class="post-content">
              <span class="post-date">
                {new Date(post.frontmatter.pubDate).toLocaleDateString(
                  "en-US",
                  {
                    year: "numeric",
                    month: "long",
                    day: "numeric",
                  }
                )}
              </span>
              <h3>{post.frontmatter.title}</h3>
              <p>{post.frontmatter.description}</p>
            </div>
        </a>
      ))
    }
  </div>
</Layout>
  
<style>
  .content {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(512px, 1fr));
    /* grid-auto-columns: 100px;
    grid-template-rows: auto; */
    width: 100%;
    box-sizing: border-box;
    gap: 1rem;
    /* padding: 1rem; */
    position: relative;

    h1 {
      display:flex;
      grid-column: 1 / -1;
    }
  }



  @media (min-width: 1240px) {
    .content   > a.latest:nth-child(1) {
      grid-column: span 2;
      grid-row: span 1;
    }
  }

  @media (min-width: 1440px) {
    .content  > a.latest:nth-child(1) {
      grid-column: span 2;
      grid-row: span 2;
    }
  }
  

  .posts {
    display: flex;
    flex-direction: row;
    gap: 1rem;
    width: 100%;
    justify-content: stretch;
  }

  .post {
    background-color: #1d1e21;
    flex-grow: 1;
    /* height: 320px; */
    border-radius: 0.75rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    /* padding: 1rem; */
  }
  .post-thumbnail {
    width: 100%;
    min-height: 256px;
    aspect-ratio: 16/8;
    /* height: 256px; */
    flex-grow: 1;
    background-size: cover;
    background-position: center;
    background-image: inherit;
  }
  .post-content {
    padding: 1rem;
  }

  .row-break {
    grid-column: 1 / -1;
    height: 0;
  }
</style>
