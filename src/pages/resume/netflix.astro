---
import Layout from "../../layouts/Layout.astro";
import ResumePage from "../../components/ResumePage";
import resumeData from "../../resume_netflix.json";
---

<title>{resumeData.name} | Resume (Netflix)</title>
<Layout maxWidth={800}>
  <ResumePage resumeData={resumeData} variant="netflix" />
  <script is:inline>
    (function () {
      function initResumeEmail() {
        const element = document.getElementById("email-link-resume");
        if (!element || !(element instanceof HTMLAnchorElement)) return;

        const reverse = (str) => str.split("").reverse().join("");
        const a = reverse(element.getAttribute("data-email-a") || "");
        const b = reverse(element.getAttribute("data-email-b") || "");
        const c = reverse(element.getAttribute("data-email-c") || "");
        const email = a + "@" + b + "." + c;

        element.href = "mailto:" + email;
        element.textContent = email;
      }

      document.addEventListener("astro:page-load", initResumeEmail);
      document.addEventListener("astro:after-swap", initResumeEmail);

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initResumeEmail);
      } else {
        initResumeEmail();
      }
    })();
  </script>
</Layout>
