---
import Layout from "../layouts/Layout.astro";
import CarouselHeader from "../components/CarouselHeader";
import PostCard from "../components/PostCard";

const matches = import.meta.glob("./blog/*.{md,mdx}", { eager: true });

// posts sorted by date, take the first 2
const posts = Object.values(matches)
  .filter((post: any) => !post.frontmatter.hidden)
  .sort((a, b) => {
    return (
      new Date(b.frontmatter.pubDate).getTime() -
      new Date(a.frontmatter.pubDate).getTime()
    );
  })
  .slice(0, 3);
---

<Layout>
  <div class="container">
    <CarouselHeader client:load />
    <div class="blurb">
      <div>
        {/* TODO: Replace with your own headline and bio */}
        <h1>YOUR HEADLINE HERE</h1>
        <p style="font-size: 1.25rem;">
          YOUR BIO HERE — drop in your Obsidian about page content.
        </p>
      </div>
    </div>

    <div class="latestPosts">
      <h2>Latest Posts</h2>
      <div class="posts">
        <!-- <CarouselHeader client:load /> -->
        {posts.map((post: any, i) => <PostCard post={post} />)}
      </div>
    </div>
  </div>
</Layout>

<style>
  .container {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    height: 100%;
    justify-content: stretch;
    /* overflow-x: hidden; */
  }
  .blurb {
    /* background-color: #1d1e21; */
    text-align: center;
    /* max-width: 800px; */
    /* margin: 4rem auto; */
    padding: 4rem;
    border-radius: 1rem;

    display: flex;
    flex-direction: column;
    justify-content: center;
    max-width: 1440px;
    margin: 0 auto;
  }
  @media (max-width: 1024px) {
    .blurb {
      padding: 2rem;
    }
  }
  .latestPosts {
    /* display: flex;
    flex-direction: column; */
    /* gap: 1rem; */
    /* flex-grow: 1; */
    /* display: flex;
    justify-content: stretch; */
    width: 100%;
    max-width: 1440px;
    margin: 0 auto;
  }
  .posts {
    display: flex;
    flex-direction: row;
    gap: 1rem;
    width: 100%;
    justify-content: stretch;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    text-decoration: none;
    color: inherit;
  }
</style>
