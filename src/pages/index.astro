---
import Layout from "../layouts/Layout.astro";
import CarouselHeader from "../components/Carousel.jsx";

const matches = import.meta.glob("./blog/*.md", { eager: true });
const posts = Object.values(matches).slice(0, 3);
---

<Layout>
  <CarouselHeader client:load />
  <div class="blurb">
    <!-- <h1>Art and Alchemy</h1> -->
    <h1>Artist by Day, Developer by Night</h1>
    <p style="font-size: 1.2rem;">
      I am a Creative Director and Engineer with over 20 years of experience in
      mobile, social, AI, and UGC platforms. I bring a visual and technical
      perspective to my approach as a creative leader with an emphasis on
      quality and the user experience.
    </p>
  </div>
  <!-- <div style="flex-grow: 1;"></div> -->
  <div class="latestPosts">
    <h2>Latest Posts</h2>
    <div class="posts">
      {
        posts.map((post: any, i) => (
          <a class="post card-container" href={post.url}>
            <div class="card shadowfx">
            <div class="post-thumbnail">
              <img
                src={post.frontmatter.image.url}
                alt={post.frontmatter.image.alt}
              />
            </div>
            <div class="post-content">
              <span class="post-date">
                {new Date(post.frontmatter.pubDate).toLocaleDateString(
                  "en-US",
                  {
                    year: "numeric",
                    month: "long",
                    day: "numeric",
                  }
                )}
              </span>
              <h3>{post.frontmatter.title}</h3>
              <p>{post.frontmatter.description}</p>
            </div>
          </div>
          </a>
        ))
      }
    </div>
  </div>
</Layout>

<style>
  .blurb {
    text-align: center;
    max-width: 800px;
    margin: 4rem auto;
  }
  .latestPosts {
    /* display: flex;
    flex-direction: column; */
    /* gap: 1rem; */
  }
  .posts {
    display: flex;
    flex-direction: row;
    gap: 1rem;
    width: 100%;
    justify-content: stretch;
  }
  .post {
    background-color: #1d1e21;
    flex-grow: 1;
    /* height: 320px; */
    border-radius: 0.75rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    /* padding: 1rem; */
  }
  .post-content {
    padding: 1rem;
  }
</style>
