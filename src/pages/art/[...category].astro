---
import Layout from "../../layouts/Layout.astro";
import Gallery from "../../components/Gallery";

const { category } = Astro.params;
const { posts } = Astro.props;

export function getStaticPaths() {
  const matches = import.meta.glob("./*.md", { eager: true });
  const posts = Object.values(matches);
  const categories = posts.flatMap((post: any) => post.frontmatter.categories);
  const uniqueCategories = [...new Set(categories)];

  const dynamicPaths = uniqueCategories.map((category) => ({
    params: { category },
    props: { posts },
  }));

  return [
    ...dynamicPaths,
    { params: { category: undefined }, props: { posts } },
  ];
}
---

<Layout
  title={"Dan Fessler | " +
    (category
      ? `${category.charAt(0).toUpperCase() + category.slice(1)} Art Portfolio`
      : "Art Portfolio")}
>
  <Gallery client:load category={category} posts={posts} baseUrl="/art" />
</Layout>
