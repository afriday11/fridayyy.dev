---
import Layout from "../../layouts/Layout.astro";
import Gallery from "../../components/Gallery";

const { category } = Astro.params;
const { posts } = Astro.props;

export function getStaticPaths() {
  const matches = import.meta.glob("./*.md", { eager: true });
  const posts = Object.values(matches);
  const filteredPosts = posts.filter((post: any) => !post.frontmatter.hidden);

  const categories = filteredPosts.flatMap(
    (post: any) => post.frontmatter.categories
  );
  const uniqueCategories = [...new Set(categories)];

  const dynamicPaths = uniqueCategories.map((category) => ({
    params: { category },
    props: { posts: filteredPosts },
  }));

  return [
    ...dynamicPaths,
    { params: { category: undefined }, props: { posts: filteredPosts } },
  ];
}
---

<Layout
  title={"Dan Fessler | " +
    (category
      ? `${category.charAt(0).toUpperCase() + category.slice(1)} Dev Portfolio`
      : "Dev Portfolio")}
>
  <Gallery
    client:load
    category={category}
    posts={posts}
    categories={["websites", "tools", "open-source", "languages", "other"]}
    baseUrl="/dev"
    persistText={false}
  />
</Layout>
