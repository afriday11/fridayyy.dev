---
import Layout from "../../layouts/Layout.astro";
import Gallery from "../../components/Gallery.astro";

const { category } = Astro.params;
const { posts } = Astro.props;

export function getStaticPaths() {
  const matches = import.meta.glob("./*.md", { eager: true });
  const posts = Object.values(matches);
  const filteredPosts = posts.filter((post: any) => !post.frontmatter.hidden);
  const categories = filteredPosts.flatMap((post: any) => post.frontmatter.categories);
  const uniqueCategories = [...new Set(categories)];

  // filter out posts with hidden:true frontmatter

  const dynamicPaths = uniqueCategories.map((category) => ({
    params: { category },
    props: { posts: filteredPosts },
  }));

  return [
    ...dynamicPaths,
    { params: { category: undefined }, props: { posts: filteredPosts } },
  ];
}
---

<head>
  <title>
    Dan Fessler - Development Portfolio {category ? `: ${category}` : ""}
  </title>
</head>

<Layout>
  <Gallery
    category={category}
    posts={posts}
    categories={["websites", "tools", "open-source", "languages", "other"]}
    baseUrl="/dev"
    persistText={false}
  />
</Layout>
