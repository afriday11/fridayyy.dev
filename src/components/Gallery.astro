---
const { category, posts, baseUrl, persistText } = Astro.props;

console.log("posts", posts);
const categories: string[] = posts
  .map((post: any) => post.frontmatter.categories)
  .flat();
const uniqueCategories = [...new Set(categories)];

const filteredPosts = category
  ? posts.filter((post: any) => post.frontmatter.categories.includes(category))
  : posts;

// sort by fromatter priority (if it exists)
const sortedPosts = filteredPosts.sort((a: any, b: any) => {
  return b.frontmatter.priority - a.frontmatter.priority;
});
---

<head>
  <title>Art Portfolio</title>
</head>

<div class="subnav">
  <div class="subnav-items">
    <a
      class={`subnav-item ${category === undefined ? "active shadowfx" : ""}`}
      href={baseUrl}>All</a
    >
    {
      uniqueCategories.map((thisCategory: string) => (
        <a
          class={`subnav-item ${thisCategory === category ? "active shadowfx" : ""}`}
          href={`${baseUrl}/${thisCategory}`}
        >
          {thisCategory}
        </a>
      ))
    }
  </div>
</div>
<div class="gallery">
  {
    sortedPosts.map((post: any) => (
      <a class="card-container" href={post.frontmatter.url || post.url}>
        <div class="card shadowfx">

          <div
            class="card-bg"
            style={`background-image: url(${post.frontmatter.thumbnail})`}
          />
          <div class="sheen" />
          <div class={`card-info ${persistText ? "persist" : ""}`}>
            <div class="title">{post.frontmatter.title}</div>
            {post.frontmatter.description && (
              <div class="description">{post.frontmatter.description}</div>
            )}
            <div class="category">{post.frontmatter.categories.join(", ")}</div>
          </div>
          {post.frontmatter.url && (
            <svg
              class="card-icon"
              stroke="currentColor"
              fill="currentColor"
              stroke-width="0"
              viewBox="0 0 512 512"
              height="1em"
              width="1em"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path d="M326.612 185.391c59.747 59.809 58.927 155.698.36 214.59-.11.12-.24.25-.36.37l-67.2 67.2c-59.27 59.27-155.699 59.262-214.96 0-59.27-59.26-59.27-155.7 0-214.96l37.106-37.106c9.84-9.84 26.786-3.3 27.294 10.606.648 17.722 3.826 35.527 9.69 52.721 1.986 5.822.567 12.262-3.783 16.612l-13.087 13.087c-28.026 28.026-28.905 73.66-1.155 101.96 28.024 28.579 74.086 28.749 102.325.51l67.2-67.19c28.191-28.191 28.073-73.757 0-101.83-3.701-3.694-7.429-6.564-10.341-8.569a16.037 16.037 0 0 1-6.947-12.606c-.396-10.567 3.348-21.456 11.698-29.806l21.054-21.055c5.521-5.521 14.182-6.199 20.584-1.731a152.482 152.482 0 0 1 20.522 17.197zM467.547 44.449c-59.261-59.262-155.69-59.27-214.96 0l-67.2 67.2c-.12.12-.25.25-.36.37-58.566 58.892-59.387 154.781.36 214.59a152.454 152.454 0 0 0 20.521 17.196c6.402 4.468 15.064 3.789 20.584-1.731l21.054-21.055c8.35-8.35 12.094-19.239 11.698-29.806a16.037 16.037 0 0 0-6.947-12.606c-2.912-2.005-6.64-4.875-10.341-8.569-28.073-28.073-28.191-73.639 0-101.83l67.2-67.19c28.239-28.239 74.3-28.069 102.325.51 27.75 28.3 26.872 73.934-1.155 101.96l-13.087 13.087c-4.35 4.35-5.769 10.79-3.783 16.612 5.864 17.194 9.042 34.999 9.69 52.721.509 13.906 17.454 20.446 27.294 10.606l37.106-37.106c59.271-59.259 59.271-155.699.001-214.959z" />
            </svg>
          )}
        </div>
      </a>
    ))
  }
</div>

<script>
  // Function to scroll to active category
  function scrollToActiveCategory() {
    const subnav = document.querySelector(".subnav");
    const activeItem = document.querySelector(".subnav-item.active");

    if (subnav && activeItem) {
      const subnavRect = subnav.getBoundingClientRect();
      const activeItemRect = activeItem.getBoundingClientRect();

      // Calculate the scroll position needed to center the active item
      const scrollLeft =
        activeItemRect.left -
        subnavRect.left -
        subnavRect.width / 2 +
        activeItemRect.width / 2;

      subnav.scrollTo({
        left: scrollLeft,
        // behavior: "smooth",
      });
    }
  }

  // Function to initialize the card animations
  function initializeCardAnimations() {
    const cardContainers =
      document.querySelectorAll<HTMLDivElement>(".card-container");

    cardContainers.forEach((cardContainer) => {
      const sheen = cardContainer.querySelector<HTMLDivElement>(".sheen");
      const card = cardContainer.querySelector<HTMLDivElement>(".card");
      const background =
        cardContainer.querySelector<HTMLDivElement>(".card-bg");

      if (!sheen || !card || !background) return;

      // Remove existing event listeners to prevent duplicates
      cardContainer.removeEventListener("mouseenter", handleMouseEnter);
      cardContainer.removeEventListener("mousemove", handleMouseMove);
      cardContainer.removeEventListener("mouseleave", handleMouseLeave);

      // Add event listeners
      cardContainer.addEventListener("mouseenter", handleMouseEnter);
      cardContainer.addEventListener("mousemove", handleMouseMove);
      cardContainer.addEventListener("mouseleave", handleMouseLeave);
    });
  }

  // Event handler functions
  function handleMouseEnter(this: HTMLDivElement) {
    const sheen = this.querySelector<HTMLDivElement>(".sheen");
    const card = this.querySelector<HTMLDivElement>(".card");
    if (!sheen || !card) return;

    card.style.transition = "all 0.1s linear";
    sheen.style.transition = "all 0.1s linear";
    sheen.style.opacity = "1";
    setTimeout(() => {
      card.style.transition = "none";
      sheen.style.transition = "none";
    }, 100);
  }

  function handleMouseMove(this: HTMLDivElement, e: MouseEvent) {
    const sheen = this.querySelector<HTMLDivElement>(".sheen");
    const card = this.querySelector<HTMLDivElement>(".card");
    if (!sheen || !card) return;

    const rect = card.getBoundingClientRect();
    const x = e.clientX - rect.left;
    const y = e.clientY - rect.top;

    const rotateY = (x / rect.width - 0.5) * 10;
    const rotateX = (y / rect.height - 0.5) * -10;

    const sheenX = (1 - x / rect.width) * 100;
    const sheenY = (1 - y / rect.height) * 100;

    card.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) translateZ(10px)`;
    sheen.style.backgroundPosition = `${100 - sheenX}% ${100 - sheenY}%`;
  }

  function handleMouseLeave(this: HTMLDivElement) {
    const sheen = this.querySelector<HTMLDivElement>(".sheen");
    const card = this.querySelector<HTMLDivElement>(".card");
    if (!sheen || !card) return;

    card.style.transition = "all 0.5s cubic-bezier(0.4, 0, 0.2, 1)";
    sheen.style.transition = "all 0.5s cubic-bezier(0.4, 0, 0.2, 1)";
    card.style.transform = "perspective(1000px) rotateX(0) rotateY(0)";
    sheen.style.opacity = "0";
    setTimeout(() => {
      card.style.transition = "none";
      sheen.style.transition = "none";
    }, 500);
  }

  // Initialize on page load
  initializeCardAnimations();
  scrollToActiveCategory();

  // Re-initialize when Astro's view transitions complete
  document.addEventListener("astro:after-swap", () => {
    initializeCardAnimations();
    scrollToActiveCategory();
  });
</script>

<style>
  .gallery {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    width: 100%;
    box-sizing: border-box;
    gap: 1rem;
    /* padding: 1rem; */
    position: relative;
  }

  .subnav {
    position: sticky;
    top: 1.5rem;
    left: 0;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 100;
    /* background: linear-gradient(to bottom, #151618, #1d1e2100); */
    margin-bottom: 1.5rem;
    a {
      text-decoration: none;
      color: inherit;
    }
  }

  @media (max-width: 1024px) {
    .subnav {
      justify-content: flex-start;
      top: 0;
      width: 100;
      left: -1rem;
      padding: 1rem;
      padding-top: 0;
      margin: 0;
      position: relative;
      overflow-x: auto;
      scrollbar-width: none;
      -ms-overflow-style: none;
      &::-webkit-scrollbar {
        display: none;
      }
    }
  }

  .subnav-items {
    text-wrap: nowrap;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    /* gap: 2rem; */
    text-transform: uppercase;
    background-color: #151618c3;
    backdrop-filter: blur(20px);
    border-radius: 100px;
    padding: 4px;
    font-size: 0.9rem;
    height: 40px;
  }

  .subnav-item {
    /* font-size: 12px; */
    /* color: #aaa; */
    cursor: pointer;
    margin: 0 1rem;
    /* line-height: 100%; */
    height: 100%;
    line-height: 40px;
  }

  .subnav-item:hover {
    color: #fff;
  }

  .subnav-item.active {
    color: #fff;
    /* padding: 12px 24px; */
    padding: 0 1rem;
    height: 100%;
    border-radius: 100px;
    background-color: #1d1e21;
    width: calc(100% + 4rem);
    /* left: -2rem; */
    position: relative;
    margin: 0;
  }

  .card {
    width: 100%;
    aspect-ratio: 1/1;
    position: relative;
    cursor: pointer;
    overflow: hidden;
    border-radius: 0.5rem;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    max-width: 480px;
  }

  .card-icon {
    position: absolute;
    top: 0;
    right: 0;
    padding: 1rem;
    fill: #fff;
    opacity: 0.75;
    /* filter: drop-shadow(0 0 2px rgba(0, 0, 0, 1)); */
    mix-blend-mode: difference;
  }

  .card-bg {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #1d1e21;
    background-size: cover;
    background-position: center;
    background-image: inherit;
    transform-origin: center center;
    background-repeat: repeat;
    /* background-scale: 2; */
    /* transform: translateZ(-100px); */
    /* scale: 1; */
    opacity: 1;
    filter: blur(0px);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .card-bg:hover {
    opacity: 0.75;
    /* scale: 0.95; */
    filter: blur(4px);
  }

  .card:hover::before {
    scale: 1;
  }

  .card-info {
    position: absolute;
    bottom: -16px;
    left: 0;
    width: 100%;
    box-sizing: border-box;
    /* height: 50%; */
    padding: 1em;
    /* background: linear-gradient(to top, rgba(0, 0, 0, 0.75), rgba(0, 0, 0, 0)); */
    /* background: rgba(0, 0, 0, 0.5); */
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    opacity: 0;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    pointer-events: none;
    z-index: 1;
    text-shadow: 0 0 10px rgba(0, 0, 0, 0.5);
    line-height: 1.2;
  }

  .card-info::before {
    content: "";
    position: absolute;
    top: -64px;
    left: 0;
    width: 100%;
    height: calc(100% + 64px);
    /* height: 100%; */
    /* background: red; */
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.8) 25%,
      rgba(0, 0, 0, 0)
    );
    /* backdrop-filter: blur(4px); */
    /* filter: blur(10px); */
    z-index: -1;
  }

  .card-info.persist,
  .card:hover .card-info {
    opacity: 1;
    bottom: 0;
  }

  .category {
    font-size: 12px;
    color: #ffffff8a;
    /* margin-top: 0.25em; */
  }

  .title {
    font-size: 18px;
    /* font-weight: 600; */
    color: #fff;
  }

  .description {
    font-size: 14px;
    color: #ffffffd6;
    margin: 0.5em 0;
    line-height: 1.25;
  }

  .sheen {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: radial-gradient(
      circle at center,
      rgba(255, 255, 255, 0.25) 0%,
      rgba(255, 255, 255, 0) 50%
    );
    background-size: 200% 200%;
    background-position: 50% 50%;
    pointer-events: none;
    z-index: 1;
    mix-blend-mode: overlay;
    opacity: 0;
    transition: opacity 0.3s ease;
  }
</style>
