---
import avatar from "../assets/avatar.jpg";
import galleryIcon from "../assets/icons/art.svg?raw";
import devIcon from "../assets/icons/dev.svg?raw";
import blogIcon from "../assets/icons/blog.svg?raw";
import resumeIcon from "../assets/icons/resume.svg?raw";
import aboutIcon from "../assets/icons/about.svg?raw";
import SocialLinks from "../components/SocialLinks.astro";
import WorkIcon from "../assets/icons/work.svg?raw";
import LocationIcon from "../assets/icons/location.svg?raw";

// Get current path
const currentPath = Astro.url.pathname;
---

<div class="container">
  <div class="sticky">
    <div class="content shadowfx">
      <div class="profile">
        <div class="avatar" style={`background-image: url(${avatar.src})`}>
        </div>
        <span class="name">DAN FESSLER</span>
        <span class="subtitle">Creative Director / Engineer</span>
        <br />
        <div class="work-location">
          <div><Fragment set:html={WorkIcon} />Incite Interactive</div>
          <div><Fragment set:html={LocationIcon} />Pacifica, CA</div>
        </div>
      </div>
      <ul class="nav">
        <a href="/" class={currentPath === "/" ? "active" : ""}>
          <li>
            <Fragment set:html={aboutIcon} />
            About
          </li>
        </a>
        <a href="/art" class={currentPath.includes("/art") ? "active" : ""}>
          <li>
            <Fragment set:html={galleryIcon} />
            Art
          </li>
        </a>
        <a href="/dev" class={currentPath.includes("/dev") ? "active" : ""}>
          <li>
            <Fragment set:html={devIcon} />
            Dev
          </li>
        </a>
        <a href="/resume" class={currentPath === "/resume" ? "active" : ""}>
          <li>
            <Fragment set:html={resumeIcon} />
            Resume
          </li>
        </a>
        <a href="/blog" class={currentPath.includes("/blog") ? "active" : ""}>
          <li>
            <Fragment set:html={blogIcon} />
            Blog
          </li>
        </a>
      </ul>
      <div style="flex-grow: 1;"></div>
      <SocialLinks />
      <div class="nav-footer">
        © {new Date().getFullYear()} Dan Fessler
      </div>
    </div>
  </div>
</div>

<script>
  function initializeMobileNav() {
    let isMobileNavOpen = false;
    document.querySelector(".menu-button").addEventListener("click", () => {
      isMobileNavOpen = !isMobileNavOpen;
      document.querySelector(".mobile-nav-content").style.bottom =
        isMobileNavOpen ? "calc(-100vh + 64px)" : "0";
    });
  }

  // Initialize on page load
  initializeMobileNav();

  // Re-initialize when Astro's view transitions complete
  document.addEventListener("astro:after-swap", initializeMobileNav);
</script>

<div class="mobile-nav">
  <div class="mobile-nav-header">
    <div class="menu-button"></div>
    <span>Dan Fessler</span>
    <div class="menu-button"></div>
  </div>
  <div class="mobile-nav-content">
    <div class="profile">
      <div class="avatar" style={`background-image: url(${avatar.src})`}></div>
      <span class="name">DAN FESSLER</span>
      <span class="subtitle">Creative Director / Engineer</span>
      <br />
      <div class="work-location">
        <div><Fragment set:html={WorkIcon} />Incite Interactive</div>
        <div><Fragment set:html={LocationIcon} />Pacifica, CA</div>
      </div>
    </div>
    <div style="flex-grow: 1;"></div>
    <ul class="nav">
      <a href="/" class={currentPath === "/" ? "active" : ""}>
        <li>
          <Fragment set:html={aboutIcon} />
          About
        </li>
      </a>
      <a href="/art" class={currentPath.includes("/art") ? "active" : ""}>
        <li>
          <Fragment set:html={galleryIcon} />
          Art
        </li>
      </a>
      <a href="/dev" class={currentPath.includes("/dev") ? "active" : ""}>
        <li>
          <Fragment set:html={devIcon} />
          Dev
        </li>
      </a>
      <a href="/resume" class={currentPath === "/resume" ? "active" : ""}>
        <li>
          <Fragment set:html={resumeIcon} />
          Resume
        </li>
      </a>
      <a href="/blog" class={currentPath.includes("/blog") ? "active" : ""}>
        <li>
          <Fragment set:html={blogIcon} />
          Blog
        </li>
      </a>
    </ul>
    <div style="flex-grow: 1;"></div>
    <SocialLinks />
    <div class="nav-footer">
      © {new Date().getFullYear()} Dan Fessler
    </div>
  </div>
</div>

<style>
  .mobile-nav {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    box-sizing: border-box;
    /* height: 100%; */
    z-index: 1000;
    flex-direction: column;
    align-items: stretch;
    /* justify-content: center; */
  }

  .mobile-nav-header {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    padding: 1rem;
    background-color: #1d1e21;
    z-index: 1;
  }

  @media (max-height: 790px) {
    .mobile-nav-content > .profile > .avatar {
      display: none;
    }
  }

  .mobile-nav-content {
    display: flex;
    flex-direction: column;
    /* align-items: center; */
    justify-content: center;
    width: 100%;
    height: calc(100vh - 3rem);
    /* transform: scaleY(0); */
    overflow: hidden;
    position: absolute;
    bottom: 0;
    transition: bottom 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    background-color: #1d1e21;
    /* z-index: 1000; */
  }

  .nav-footer {
    margin-bottom: calc(100vh - 100svh);
  }

  .menu-button {
    width: 2rem;
    height: 2rem;
    background-color: #fff;
    border-radius: 50%;
  }

  .container {
    display: flex;
    flex-direction: column;
    width: 25%;
    min-width: 320px;
    max-width: 400px;
    position: relative;
    height: calc(100vh - 3rem);
    text-align: center;
    position: sticky;
    top: 1.5rem;
    /* border-radius: 1rem; */
  }

  @media (max-width: 1024px) {
    .container {
      display: none;
    }

    .mobile-nav {
      display: flex;
    }

    /* .mobile-nav-content {
      display: flex;
    } */
  }

  .container .sticky {
    width: 100%;
    flex-grow: 1;
    box-sizing: border-box;
  }

  .content {
    position: relative;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #1d1e21;
    border-radius: 1rem;
    display: flex;
    flex-direction: column;
  }

  .profile {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 2em;
  }

  .subtitle {
    font-size: 0.9em;
  }

  .work-location {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5em;
    font-size: 0.9em;
  }

  .avatar {
    width: 148px;
    height: 148px;
    border-radius: 50%;
    overflow: hidden;
    margin: 0 auto;
    margin-bottom: 1em;
    background-size: cover;
    position: relative;
    box-shadow: 0 2px 20px black;
    /* background-color: #fff; */
    img {
      width: 100%;
    }
  }

  .avatar::after {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    mix-blend-mode: screen;
    box-shadow:
      1px 1px 1px 0 rgb(255, 255, 228) inset,
      -1px -1px 1px 0 rgba(180, 228, 255, 0.38) inset;
  }

  .name {
    font-size: 34px;
    font-weight: 300;
    color: #ddd;
    position: relative;
    perspective: 100px;
  }

  .name::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #00000047;
    filter: blur(20px);
    transform: scale(1, 0.5);
    transform-origin: center 85%;
    z-index: -1;
  }

  .nav {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: stretch;
    list-style: none;
    padding: 0;
    margin: 0;

    a {
      text-transform: uppercase;
      width: 100%;

      color: #666;
      text-decoration: none;
      transition: color 0.3s ease;

      li {
        display: flex;
        align-items: center;
        justify-content: space-between;
        width: 100%;
        height: 60px;
        padding: 0 2rem;
        box-sizing: border-box;
      }

      svg {
        fill: inherit;
      }

      &.active {
        background-color: rgba(0, 0, 0, 0.125);
        color: white;
        svg {
          fill: white;
        }
      }

      &:hover {
        background-color: rgba(0, 0, 0, 0.125);
        cursor: pointer;

        a {
          color: white;
        }
      }
    }
  }

  .nav-footer {
    padding: 16px;
    font-size: 12px;
    display: flex;
    justify-content: center;
  }
</style>
