---
const matches = import.meta.glob("../pages/gallery/*.md", { eager: true });
const posts = Object.values(matches);

const { category } = Astro.props;

const filteredPosts = category
  ? posts.filter((post: any) => post.frontmatter.categories.includes(category))
  : posts;

const shuffled = filteredPosts.sort(() => 0.5 - Math.random());
---

<head>
  <title>Gallery</title>
</head>

<div class="subnav">
  <div class="subnav-items">
    <a
      class={`subnav-item ${category === undefined ? "active shadowfx" : ""}`}
      href="/gallery">All</a
    >
    <a
      class={`subnav-item ${category === "3d-modeling" ? "active shadowfx" : ""}`}
      href="/gallery/3d-modeling">3D Modeling</a
    >
    <a
      class={`subnav-item ${category === "concept" ? "active shadowfx" : ""}`}
      href="/gallery/concept">Concept</a
    >
    <a
      class={`subnav-item ${category === "pixel" ? "active shadowfx" : ""}`}
      href="/gallery/pixel">Pixel</a
    >
    <a
      class={`subnav-item ${category === "direction" ? "active shadowfx" : ""}`}
      href="/gallery/direction">Direction</a
    >
    <a
      class={`subnav-item ${category === "personal" ? "active shadowfx" : ""}`}
      href="/gallery/personal">Personal</a
    >
  </div>
</div>
<div class="gallery">
  {
    shuffled.map((post: any) => (
      <a class="card-container" href={post.url}>
        <div class="card shadowfx">
          {/* <div
            class="card-bg"
            style={`background-image: url(${post.frontmatter.thumbnail})`}
          /> */}
          <img class="" src={post.frontmatter.thumbnail} />
          <div class="sheen" />
          <div class="card-info">
            <div class="category">{post.frontmatter.categories.join(", ")}</div>
            <div class="title">{post.frontmatter.title}</div>
          </div>
        </div>
      </a>
    ))
  }
</div>

<script>
  const cardContainers =
    document.querySelectorAll<HTMLDivElement>(".card-container");

  cardContainers.forEach((cardContainer) => {
    const sheen = cardContainer.querySelector<HTMLDivElement>(".sheen");
    const card = cardContainer.querySelector<HTMLDivElement>(".card");
    const background = cardContainer.querySelector<HTMLDivElement>(".card-bg");

    if (!sheen || !card || !background) return;
    cardContainer.addEventListener("mouseenter", () => {
      card.style.transition = "all 0.1s linear";
      sheen.style.transition = "all 0.1s linear";
      sheen.style.opacity = "1";
      setTimeout(() => {
        card.style.transition = "none";
        sheen.style.transition = "none";
      }, 100);
    });

    cardContainer.addEventListener("mousemove", (e) => {
      const rect = card.getBoundingClientRect();
      const x = e.clientX - rect.left; // x position within the element
      const y = e.clientY - rect.top; // y position within the element

      // Calculate rotation values (max 15 degrees)
      const rotateY = (x / rect.width - 0.5) * 10;
      const rotateX = (y / rect.height - 0.5) * -10;

      // Calculate sheen position (opposite to mouse)
      const sheenX = (1 - x / rect.width) * 100;
      const sheenY = (1 - y / rect.height) * 100;

      card.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) translateZ(10px)`;
      sheen.style.backgroundPosition = `${100 - sheenX}% ${100 - sheenY}%`;
      // background.style.transform = `translate(${(sheenX / 2 - 25) / 10}%, ${(sheenY / 2 - 25) / 10}%)`;
    });

    cardContainer.addEventListener("mouseleave", () => {
      card.style.transition = "all 0.5s cubic-bezier(0.4, 0, 0.2, 1)";
      sheen.style.transition = "all 0.5s cubic-bezier(0.4, 0, 0.2, 1)";
      card.style.transform = "perspective(1000px) rotateX(0) rotateY(0)";
      // background.style.transform = "translate(0, 0)";
      sheen.style.opacity = "0";
      setTimeout(() => {
        card.style.transition = "none";
        sheen.style.transition = "none";
      }, 500);
    });
  });
</script>

<style>
  .gallery {
    /* display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); */
    width: 100%;
    box-sizing: border-box;
    gap: 1rem;
    /* padding: 1rem; */
    position: relative;
    columns: 3;
  }

  .subnav {
    position: sticky;
    top: 1rem;
    left: 0;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 100;
    /* background: linear-gradient(to bottom, #151618, #1d1e2100); */
    margin-bottom: 1rem;
    a {
      text-decoration: none;
      color: inherit;
    }
  }

  .subnav-items {
    text-wrap: nowrap;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    /* gap: 2rem; */
    text-transform: uppercase;
    background-color: #151618c3;
    backdrop-filter: blur(20px);
    border-radius: 100px;
    padding: 4px;
    font-size: 0.9rem;
    height: 40px;
  }

  .subnav-item {
    /* font-size: 12px; */
    /* color: #aaa; */
    cursor: pointer;
    margin: 0 1rem;
    /* line-height: 100%; */
    height: 100%;
    line-height: 40px;
  }

  .subnav-item:hover {
    color: #fff;
  }

  .subnav-item.active {
    color: #fff;
    /* padding: 12px 24px; */
    padding: 0 1rem;
    height: 100%;
    border-radius: 100px;
    background-color: #1d1e21;
    width: calc(100% + 4rem);
    /* left: -2rem; */
    position: relative;
    margin: 0;
  }

  .card {
    width: 100%;

    /* aspect-ratio: 1/1; */
    position: relative;
    cursor: pointer;
    overflow: hidden;
    border-radius: 0.5rem;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);

    margin-bottom: 1rem;
  }

  .card-bg {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
    background-image: inherit;
    transform-origin: center center;
    background-repeat: no-repeat;
    /* background-scale: 2; */
    /* transform: translateZ(-100px); */
    scale: 1;
    transition: scale 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .card-bg:hover {
    scale: 1.05;
    /* scale: 1.025; */
  }

  .card:hover::before {
    scale: 1;
  }

  .card-info {
    position: absolute;
    bottom: -16px;
    left: 0;
    width: 100%;
    box-sizing: border-box;
    /* height: 50%; */
    padding: 1em;
    /* background: linear-gradient(to top, rgba(0, 0, 0, 0.75), rgba(0, 0, 0, 0)); */
    /* background: rgba(0, 0, 0, 0.5); */
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    opacity: 0;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    pointer-events: none;
    z-index: 1;
    text-shadow: 0 0 10px rgba(0, 0, 0, 0.5);
  }

  .card-info::before {
    content: "";
    position: absolute;
    top: -64px;
    left: 0;
    width: 100%;
    height: calc(100% + 64px);
    /* height: 100%; */
    /* background: red; */
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.5) 50%,
      rgba(0, 0, 0, 0)
    );
    z-index: -1;
  }

  .card:hover .card-info {
    opacity: 1;
    bottom: 0;
  }

  .category {
    font-size: 12px;
    color: #ffffff8a;
  }

  .title {
    font-size: 20px;
    /* font-weight: 600; */
    color: #fff;
  }

  .sheen {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: radial-gradient(
      circle at center,
      rgba(255, 255, 255, 0.25) 0%,
      rgba(255, 255, 255, 0) 50%
    );
    background-size: 200% 200%;
    background-position: 50% 50%;
    pointer-events: none;
    z-index: 1;
    mix-blend-mode: overlay;
    opacity: 0;
    transition: opacity 0.3s ease;
  }
</style>
